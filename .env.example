# Generate a strong value with: openssl rand -hex 32
PROXY_AUTH_TOKEN=replace-with-a-long-random-secret

# Optional comma-separated targets that can be proxied without X-Proxy-Token.
PROXY_AUTH_WHITELIST=

# Optional comma-separated domain rules. Empty allows all target domains.
PROXY_DOMAIN_WHITELIST=

# Optional password for the /logs page. Empty disables the page.
PROXY_LOG_PASSWORD=

# Optional in-memory request log size. Defaults to 200.
PROXY_LOG_LIMIT=200

# Optional timezone for the /logs page. Defaults to Asia/Shanghai.
PROXY_LOG_TIMEZONE=Asia/Shanghai
